# Copy this file to .env.local and fill in real values
# NEVER commit .env.local to git

# Supabase — get from supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co

# Service role key — used by the data scripts (collect / sync / curate) for WRITES.
# It BYPASSES Row Level Security. Keep it ONLY here and in GitHub Actions secrets.
# NEVER expose it to the frontend or commit it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Anon key — read-only public key for the Next.js frontend (safe to ship to browser).
SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# GitHub Personal Access Token — github.com/settings/tokens
# Push from CI/local needs: repo + workflow
GITHUB_TOKEN=ghp_your_token_here

# PostHog analytics (optional) — posthog.com → Project Settings → Project API Key.
# Leave the key empty to skip analytics; the provider handles a missing key.
NEXT_PUBLIC_POSTHOG_KEY=phc_your_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Base URL — used by sitemap.ts. localhost for dev; your real domain on deploy.
NEXT_PUBLIC_BASE_URL=https://your-domain.com
