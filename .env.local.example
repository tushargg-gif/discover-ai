# Copy this file to .env.local and fill in real values
# NEVER commit .env.local to git

# Supabase — get from supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co

# Service role key — used by the data scripts (collect / sync / curate) for WRITES.
# It BYPASSES Row Level Security. Keep it ONLY here and in GitHub Actions secrets.
# NEVER expose it to the frontend or commit it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Anon key — read-only public key for the Next.js frontend (safe to ship to browser).
SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# GitHub Personal Access Token — github.com/settings/tokens
# Only needs: public_repo (read-only)
GITHUB_TOKEN=ghp_your_token_here
