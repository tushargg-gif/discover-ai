# Copy this file to .env.local and fill in real values
# NEVER commit .env.local to git

# Supabase — get from supabase.com → your project → Settings → API
# The unprefixed pair is used by the data scripts (collect / sync).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# The NEXT_PUBLIC_ pair is used by the Next.js frontend (same values).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# GitHub Personal Access Token — github.com/settings/tokens
# Only needs: public_repo (read-only)
GITHUB_TOKEN=ghp_your_token_here
